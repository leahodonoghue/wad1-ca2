 <div class="ui card" id="city{{@index}}">

        <div class="image">
            <img src="/{{image}}" alt="{{city}}">
        </div>

        <div class="content">

               <div class="header">{{city}}</div>
        
          
               <div class="meta">{{type}}</div>
     
           
            <div class="description">
               <i class="star icon"></i> Famous For: {{popular}}
               {{#if rating}}
                 <p>
                     <span 
                        class="ui yellow disabled rating" 
                        data-icon="star" 
                        data-rating="{{rating}}" 
                        data-max-rating="5">
                    </span>

                    <span style="color: grey; font-size: 90%; font-style: italic">
                         {{highlightPopular rating}}
                    </span>
                 </p>
               {{/if}}
            </div>
        </div>

    <div class="extra content">

       <button type="submit" class="editSubmit" id="showEdit{{@index}}">
        <i class="ui pencil icon"></i>
       </button>

      <a href="/travel/{{countryId}}/deletedestination/{{id}}" 
         title="Delete city">
        <i class="ui black trash icon"></i>
      </a>
    </div>
</div>