      <div class="ui card" id="city{{@index}}">
        <div class="image">
          <img src="{{picture.url}}">
        </div>
        <div class="content">
          <a class="header">{{uppercase city}}</a> 
          <div class="meta">{{type}}</div>
          <p>
        
        <div class="description">
            Famous for: {{popular}}
        </div>
          {{#if rating}}
            <p>
                <span 
                   class="ui yellow disabled rating" 
                   data-icon="star" 
                   data-rating="{{rating}}" 
                   data-max-rating="5">
                </span>

                <span style="color: grey; font-size: 90%; font-style: italic">
                {{highlightPopular rating}}
              </span>
            </p>
          {{/if}}
        </div>
        
        <div class="extra content">

          <button type="button"  id="showEdit{{@index}}">
            <i class="ui black pencil icon"></i>
          </button>

          <a href="/travel/{{countryId}}/deletedestination/{{id}}" >
            <i class="ui black trash icon"></i>
          </a>
        </div>
          
      </div>
