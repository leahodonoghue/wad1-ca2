<form class="ui stacked segment form" action="/travel/{{id}}/addcity" method="POST">
  <div class="two fields">
    <div class="field">
      <label>City</label>
      <input type="text" name="city" autofocus required title = "Please include a valid city"
	  placeholder="City Name">
    </div>
    <div class="field">
      <label>type</label>
      <input type="text" name="type" required title = "Please include the type of city"
	  placeholder="City Type"  >
    </div>
     <div class="field">
      <label>Famous For</label>
      <input type="text" name="popular" autofocus required title = "Please include a valid popularity"
	  placeholder="What it's famous for">
    </div>
    <div class="field">
      <label>Rating</label>
      <input type="text" name="rating"  required title = "Please give a rating"
	  placeholder="Give a rating (1-5)">
    </div>
  </div>
  <button class="ui blue submit button">Add City</button>
</form>
