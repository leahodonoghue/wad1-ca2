<section class="ui segment">


{{#if destinations}}
<div class="ui three stackable cards">
{{#each destinations}}

     {{> cityCard countryId=../id}}
     {{> editCity countryId=../id}}

     <script>
    document.querySelector("#showEdit{{@index}}").addEventListener ('click', () => {
        document.querySelector("#city{{@index}}").style.display = "none";
        document.querySelector("#edit{{@index}}").style.display = "table-row";
    });
    document.querySelector("#hideEdit{{@index}}").addEventListener ('click', () => {
        document.querySelector("#city{{@index}}").style.display = "table-row";
        document.querySelector("#edit{{@index}}").style.display = "none";
    });
</script>

{{/each}}

</div>

  {{else}}
    <h3 class="ui message">
     Empty Destination List!
    </h3>

{{/if}}

</section>