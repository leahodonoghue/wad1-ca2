<section class="dashboard-header">

  <h2 class="title">Travel App Dashboard</h2>

    <form action="/searchCategory" method="GET" class="ui form">
        
      <div class="ui inline fields">
        <div class="field">
          <input type="text" name="searchTerm" placeholder="Search by country..." value="{{search}}">
        </div>

        <div class="field">
          <label>Sort by:</label>
          <select class="ui dropdown" name="sort" onchange="this.form.submit()">
            <option value="country" {{#if countrySelected}}selected{{/if}}>Country</option>
          </select>
        </div>

        <div class="field">
          <label>Order:</label>
          <select class="ui dropdown" name="order" onchange="this.form.submit()">
            <option value="asc" {{#if ascSelected}}selected{{/if}}>↑</option>
            <option value="desc" {{#if descSelected}}selected{{/if}}>↓</option>
          </select>
        </div>
      </div>

    </form>


</section>


{{#if destinations}}

<div class="ui three stackable cards">

  {{#each destinations}}
  <div class="ui card">

<div class="image">
    <img src="{{picture.url}}">
</div>

    <div class="content">
      <div class="header">
        {{uppercase country}}
      </div>
    </div>

    <div class="content">
      <p>Total cities: {{destinations.length}}</p>
      {{#if date}}
      <p>
        <i class="calendar alternate outline icon"></i>
        Created on <i>{{formatDate date}}</i>
      </p>
      {{/if}}
    </div>

    <div class="extra content">
      <a href="/travel/{{id}}">
        <i class="ui open folder outline black icon"></i> View
      </a>
      <a href="dashboard/deletecountry/{{id}}">
        <i class="ui trash black icon"></i>
      </a>
    </div>

  </div>
  {{/each}}

</div>

{{else}}

{{#unless search}}
    <h3 class="ui message">
       Start adding your playlists!
    </h3>
{{/unless}}


{{/if}}