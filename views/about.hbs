{{> menu id="about"}}

<section class="ui left aligned middle aligned segment">

   <h2>About the Travel Destination App</h2>
   <p>
    all about the app
   </p>

<img src = "/map.png" class = "ui centered image">

<div class="ui five statistics" style="margin-top: 1em;">

  <div class="statistic">
    <div class="value">
      <i class="music icon"></i>
    </div>
    <div class="label">
        App Title: <br>
        {{info.appTitle}}
    </div>
  </div>
  <!-- other statistics will go here -->
    <div class="statistic">
    <div class="value">
      <i class="code branch icon"></i>
    </div>
    <div class="label">
        App Version: <br>
        {{info.version}}
    </div>
  </div>
    <div class="statistic">
    <div class="value">
      <i class="map pin icon"></i>
    </div>
    <div class="label">
        Made in: <br>
        {{info.location}}
    </div>
  </div>
    <div class="statistic">
    <div class="value">
      <i class="user icon"></i>
    </div>
    <div class="label">
        Created by: <br>
        {{info.creators.0.name}}
    </div>
  </div>
    <div class="statistic">
    <div class="value">
      <i class="user plus icon"></i>
    </div>
    <div class="label">
        With help from: <br>
        {{info.creators.1.name}}
    </div>
  </div>
</div>
</section>