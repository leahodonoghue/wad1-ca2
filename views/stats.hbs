{{> menu id="stats"}}

<section class="ui center aligned middle aligned segment">

  <h2>Travel App Statistics</h2>

  <h3 class="ui header">
    App Statistics
  </h3>
  <p>
    The travel app now contains: 
  </p>
  {{#with stats}}
   <div class="ui center aligned grid">
    
    <div class = "ui sixteen wide column">
      
        <div class="ui centered three statistics">

            <div class="ui purple statistic">
            <div class="value">
              <i class="users icon"></i> 
            </div>
            <div class="label">
              {{displayNumUsers}} users
            </div>
          </div>

          <div class="ui red statistic">
            <div class="value">
              <i class="flag icon"></i> 
            </div>
            <div class="label">
              {{displayNumCountries}} countries
            </div>
          </div>

          <div class="ui green statistic">
            <div class="value">
              <i class="map icon"></i> 
            </div>
            <div class="label">
              {{displayNumCities}} cities
            </div>
          </div> 
		  
          <div class="ui blue statistic">
            <div class="value">
              <i class="balance scale icon"></i> 
            </div>
            <div class="label">
              Average cities per <br> country: {{displayAverage}}
            </div>
          </div>  

          <div class="ui yellow statistic">
            <div class="value">
              <i class="star icon"></i> 
            </div>
            <div class="label">
              Highest rated cities: {{highest}} stars
              <table>
              {{#each displayFav}}
              <tr>
                <td>{{this}}</td>
              </tr>
              {{/each}}
            </table>
            </div>
          </div>  


		  
        </div> 
    </div>
   </div>   
  {{/with}}
</section>
